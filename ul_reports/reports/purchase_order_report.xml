<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PAPER FORMAT -->
    <record id="paperformat_ul_purchase_order" model="report.paperformat">
        <field name="name">UL Purchase Order Paperformat</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
    </record>

    <!-- REPORT -->
    <record id="action_report_ul_purchase_order" model="ir.actions.report">
        <field name="name">UL Purchase Order</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ul_reports.report_ul_purchase_order</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="paperformat_id" ref="ul_reports.paperformat_ul_purchase_order"/>
    </record>

    <!-- STYLES -->
    <template id="report_ul_shared_styles">
        <style>
            body { font-family: Arial; font-size: 12px; }

            .title {
                font-size: 26px;
                font-weight: bold;
                text-align: right;
                color: #003366;
            }

            .blue { background:#003366; color:#fff; }

            .box {
                border:1px solid #003366;
                padding:10px;
                min-height:80px;
            }

            .table { width:100%; border-collapse:collapse; margin-top:15px; }

            .table th {
                background:#003366;
                color:#fff;
                padding:8px;
                text-align:left;
            }

            .table td {
                padding:8px;
                border-bottom:1px solid #ccc;
            }

            .info-table {
                width: 70%;
                float: right;
                border-collapse: collapse;
            }

            .info-table th {
                background:#003366;
                color:#fff;
                padding:6px;
                width:50%;
                text-align:left;
            }

            .info-table td {
                border:1px solid #003366;
                padding:6px;
                text-align:right;
            }

            .total-box {
                width: 250px;
                float:right;
                margin-top:20px;
                border-collapse: collapse;
            }

            .total-box th {
                background:#003366;
                color:#fff;
                padding:8px;
                text-align:left;
            }

            .total-box td {
                border:1px solid #003366;
                padding:8px;
                text-align:right;
                font-weight:bold;
            }

            .row { display:flex; margin-top:20px; }
            .col-6 { width:50%; padding-right:10px; }
        </style>
    </template>

    <!-- MAIN -->
    <template id="report_ul_purchase_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="ul_reports.report_ul_purchase_order_document"/>
            </t>
        </t>
    </template>

    <!-- DOCUMENT -->
    <template id="report_ul_purchase_order_document">
        <t t-call="web.basic_layout">
            <div class="page">
                <t t-call="ul_reports.report_ul_shared_styles"/>

                <!-- HEADER -->
                <div style="display:flex;">
                    <div style="width:50%;">
                        <img t-if="o.company_id.logo"
                             t-att-src="image_data_uri(o.company_id.logo)"
                             style="max-height:80px;"/>

                        <div><t t-esc="o.company_id.name"/></div>
                        <div><t t-esc="o.company_id.street"/></div>
                        <div><t t-esc="o.company_id.city"/></div>
                        <div>Phone: <t t-esc="o.company_id.phone"/></div>
                    </div>

                    <div style="width:50%;">
                        <div class="title">PURCHASE ORDER</div>

                        <table class="info-table">
                            <tr>
                                <th>TRANSACTION NO.</th>
                                <td><t t-esc="o.name"/></td>
                            </tr>
                            <tr>
                                <th>DATE</th>
                                <td><span t-field="o.date_order"/></td>
                            </tr>
                            <tr>
                                <th>ACCOUNT</th>
                                <td><t t-esc="o.partner_id.ref or ''"/></td>
                            </tr>
                            <tr>
                                <th>TERMS</th>
                                <td><t t-esc="o.payment_term_id.name or ''"/></td>
                            </tr>
                            <tr>
                                <th>SHIP VIA</th>
                                <td><t t-esc="o.partner_id.name or ''"/></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- VENDOR / SHIP TO -->
                <div class="row">
                    <div class="col-6">
                        <div class="blue" style="padding:6px;">VENDOR</div>
                        <div class="box">
                            <t t-esc="o.partner_id.name"/>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="blue" style="padding:6px;">SHIP TO</div>
                        <div class="box">
                            <span t-field="o.partner_id"
                               t-options='{"widget":"contact","fields":["name","address"],"no_marker":True}'/>
                        </div>
                    </div>
                </div>

                <!-- PRODUCTS -->
                <table class="table">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>QTY</th>
                            <th>UM</th>
                            <th>DESCRIPTION</th>
                            <th>UNIT PRICE</th>
                            <th>EXTENDED PRICE</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="o.order_line.filtered(lambda l: not l.display_type)" t-as="line">
                            <td><t t-esc="line.product_id.default_code"/></td>
                            <td><t t-esc="line.product_qty"/></td>
                            <td><t t-esc="line.product_uom.name"/></td>
                            <td><t t-esc="line.name"/></td>
                            <td>
                                <span t-field="line.price_unit"
                                   t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                            </td>
                            <td>
                                <span t-field="line.price_subtotal"
                                   t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- TOTAL -->
                <table class="total-box">
                    <tr>
                        <th>TOTAL ORDER</th>
                        <td>
                            <span t-field="o.amount_total"
                               t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                        </td>
                    </tr>
                </table>

            </div>
        </t>
    </template>

</odoo>