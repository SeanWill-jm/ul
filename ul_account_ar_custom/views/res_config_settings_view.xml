<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_ul_stock" model="ir.ui.view">
        <field name="name">res.config.settings.view.ul.stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <block name="operations_setting_container" position="inside">
                <setting id="no_backorder" string="No Backorder on Partial Validation"
                    help="When enabled, validating a picking with less quantity will automatically cancel remaining quantities without asking to create a backorder.">
                    <field name="no_backorder"/>
                </setting>
            </block>
        </field>
    </record>

</odoo>
