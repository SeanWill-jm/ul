<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_product_view_kanban_catalog_inherit_zoom" model="ir.ui.view">
        <field name="name">product.product.kanban.catalog.inherit.zoom</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_view_kanban_catalog"/>
        <field name="arch" type="xml">
            <!-- Ensure image_1920 is available for the zoom preview -->
            <xpath expr="//kanban" position="inside">
                <field name="image_1920" invisible="1"/>
            </xpath>
            <!-- Update the image field to enable zoom -->
            <xpath expr="//field[@name='image_128']" position="attributes">
                <attribute name="options">{'zoom': true, 'preview_image': 'image_1920', 'size': [55, 55], 'img_class': 'object-fit-contain'}</attribute>
                <attribute name="class" add="o_kanban_image_zoom ul_clickable_image" separator=" "/>
            </xpath>
        </field>
    </record>
</odoo>
